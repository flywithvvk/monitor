# Backend Environment Variables

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# SMTP Email Configuration (for alerts)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=alert-recipient@email.com

# API Keys for Threat Intelligence
ABUSEIPDB_API_KEY=your_abuseipdb_api_key
IPQUALITYSCORE_KEY=your_ipqualityscore_api_key

# Security
INTERNAL_TOKEN=generate_random_secure_token_here
OWNER_KNOWN_IPS=192.168.1.100,203.0.113.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app

# Optional: Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Server Configuration
PORT=3000
NODE_ENV=production
